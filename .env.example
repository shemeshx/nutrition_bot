# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Deployment ────────────────────────────────────────────────────────────────
WEBHOOK_URL=https://your-app.up.railway.app

# ── LLM Provider (choose one: openrouter / openai / anthropic / ollama) ───────
LLM_PROVIDER=openrouter
LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# OpenRouter (supports Claude, GPT, Llama, Gemma, Mistral in one API)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (direct GPT)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic (direct Claude)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Ollama (local models)
# OLLAMA_BASE_URL=http://localhost:11434

# ── Database (Railway volume mounted at /app/data) ────────────────────────────
DB_PATH=/app/data/nutrition.db
CHECKPOINT_DB_PATH=/app/data/checkpoints.db

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
